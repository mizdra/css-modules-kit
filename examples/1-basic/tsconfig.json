{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2015",
    "lib": ["ES2015"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "noEmit": true,
