{
  "name": "css-modules-kit-monorepo",
  "private": true,
  "license": "MIT",
  "author": "mizdra <pp.mizdra@gmail.com>",
  "repository": "https://github.com/mizdra/css-modules-kit.git",
  "workspaces": [
    "packages/core",
    "packages/codegen",
    "packages/ts-plugin",
    "packages/vscode",
    "packages/stylelint-plugin",
    "packages/eslint-plugin",
    "crates/zed"
  ],
  "type": "module",
  "scripts": {
    "version": "./scripts/version.sh",
    "build": "tsc -b tsconfig.build.json",
    "lint": "run-s -c lint:*",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint --type-aware --type-check",
    "lint-fix": "run-s -c lint-fix:*",
    "lint-fix:oxfmt": "oxfmt --write",
    "lint-fix:oxlint": "npm run lint:oxlint -- --fix",
    "test": "vitest --run",
    "vscode-test": "vscode-test",
    "update-generated-in-examples": "./scripts/update-generated-in-examples.sh"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/css": "^1.1.0",
    "@mizdra/inline-fixture-files": "^2.1.1",
    "@mizdra/oxlint-config": "^0.3.0",
    "@types/node": "^25.3.0",
    "@types/postcss-safe-parser": "^5.0.4",
    "@types/react": "^19.2.14",
    "@types/vscode": "^1.109.0",
    "@typescript/server-harness": "^0.3.5",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "dedent": "^1.7.2",
    "eslint": "^10.2.0",
    "npm-run-all2": "^8.0.4",
    "ovsx": "^0.10.10",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "stylelint": "^17.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
}
